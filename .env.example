NODE_ENV=production
PORT=3000

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production-use-strong-random-string
JWT_EXPIRY=30d

# Database path
DB_PATH=/app/data/catalog.db

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Android License API Key
DEFAULT_API_KEY=dev-api-key-change-in-production
